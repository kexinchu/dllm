\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Avg\_Std@top1\_prob (per-token std of the top-1 logprob across $bs\!\in \!\{1,8,32\}$, averaged over token positions and problems) on MATH500. \textsc  {DetermLLM}\xspace  matches or beats LayerCast on every model; the gap is largest on Llama-8B (\textsc  {DetermLLM}\xspace  $0.060$ vs.\ LayerCast $0.076$, BF16 $0.072$). Log $y$ axis because Phi-4 values are $20\times $ smaller.\relax }}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:avgstd}{{3}{8}{Avg\_Std@top1\_prob (per-token std of the top-1 logprob across $bs\!\in \!\{1,8,32\}$, averaged over token positions and problems) on MATH500. \dllm matches or beats LayerCast on every model; the gap is largest on Llama-8B (\dllm $0.060$ vs.\ LayerCast $0.076$, BF16 $0.072$). Log $y$ axis because Phi-4 values are $20\times $ smaller.\relax }{figure.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Per-call GEMM latency summed over DeepSeek-R1-Distill-Qwen-7B's 8 projection shapes (attn $q/k/v/o$, ffn gate/up/down, lm\_head) across $M\!\in \!\{1,8,16,32\}$. Triton's $\sim \!67\,\mu $s launch-overhead floor dominates small-$N$ shapes (GQA K/V at $N\!=\!512$); LayerCast's upcast dominates every shape. The hybrid dispatcher routes by $N$ and matches BF16 baseline within 0.1\%.\relax }}{8}{table.caption.6}\protected@file@percent }
\newlabel{tab:overhead_op}{{3}{8}{Per-call GEMM latency summed over DeepSeek-R1-Distill-Qwen-7B's 8 projection shapes (attn $q/k/v/o$, ffn gate/up/down, lm\_head) across $M\!\in \!\{1,8,16,32\}$. Triton's $\sim \!67\,\mu $s launch-overhead floor dominates small-$N$ shapes (GQA K/V at $N\!=\!512$); LayerCast's upcast dominates every shape. The hybrid dispatcher routes by $N$ and matches BF16 baseline within 0.1\%.\relax }{table.caption.6}{}}
